{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "muqt",
  "version": "1.0.0",
  "description": "MuQt - Cross-platform PDF viewer built with Qt6 and MuPDF",
  "dependencies": [
    {
      "name": "opencv4",
      "default-features": false,
      "platform": "windows"
    },
    {
      "name": "onnxruntime",
      "platform": "windows"
    },
    {
      "name": "libmupdf",
      "default-features": false,
      "platform": "windows"
    }
  ]
}